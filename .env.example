# @required
# @desc: PostgreSQL connection string
# @type: url
DATABASE_URL=

# @required
# @desc: Secret key for JWT signing
APP_SECRET=

# @type: number
# @desc: Port the server listens on
PORT=3000

# @type: boolean
DEBUG=false

# @type: email
# @desc: Admin notification email
ADMIN_EMAIL=

# @type: url
REDIS_URL=redis://localhost:6379

# @type: /^[a-z]+-[a-z]+-[0-9]+$/
# @desc: AWS region, e.g. us-east-1
AWS_REGION=us-east-1

# @type: /^v[0-9]+\.[0-9]+\.[0-9]+$/
# @desc: Semver app version, e.g. v1.2.3
APP_VERSION=

# @required
# @type: /^[A-Z]{3}$/
# @desc: ISO currency code, e.g. USD, EUR
CURRENCY=USD

STRIPE_KEY=
